def calculadora ():

    num1 = float(input("primeiro numero: "))
    num2 = float(input("segundo numero: "))
    
    print ("1. Soma \n 2. Subtracao \n 3. Multiplicacao \n 4.Divisao ")
    operacao = int(input("operacao: "))

    if operacao == 1: 
        return  num1 + num2
    elif operacao == 2: 
        return num1 - num2
    elif operacao == 3:
        return num1 * num2
    elif operacao == 4: 
        return num1 / num2
    else: return 0

resultado = calculadora()
print(f"resultado: {resultado}")